{
  "name": "trusted-publisher",
  "version": "0.1.3",
  "description": "Bulk configure npm trusted publishing for GitHub monorepos.",
  "keywords": [
    "cli",
    "github-actions",
    "monorepo",
    "npm",
    "oidc",
    "trusted-publishing"
  ],
  "homepage": "https://github.com/jskits/trusted-publisher#readme",
  "bugs": {
    "url": "https://github.com/jskits/trusted-publisher/issues"
  },
  "license": "MIT",
  "author": "JS Kits",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jskits/trusted-publisher.git"
  },
  "bin": {
    "trusted-publisher": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist coverage .turbo",
    "dev": "tsdown --watch",
    "lint:package": "publint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "15.0.0",
    "picocolors": "1.1.1",
    "tinyexec": "1.2.4",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "publint": "0.3.21",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
