{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": true,
  "sortPackageJson": true,
  "ignorePatterns": ["node_modules/**", "dist/**", "coverage/**", ".turbo/**", "pnpm-lock.yaml"]
}
